# Copy this file to .env before running docker-compose.
# Replace placeholder values with your own. Do not commit .env.

# PostgreSQL (used by both Postgres container and Keycloak)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-local-password

# Keycloak admin console (http://localhost:8080)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-strong-local-password

# RabbitMQ (http://localhost:15672)
# These have defaults in docker-compose.yml — override here if needed.
RABBITMQ_DEFAULT_USER=jobflow
RABBITMQ_DEFAULT_PASS=jobflow-local-rabbitmq-password
